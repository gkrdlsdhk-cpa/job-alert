<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jobalert.pwc-watch</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/kimhakin/job-alert/.venv/bin/python3</string>
        <string>/Users/kimhakin/job-alert/pwc_watch.py</string>
    </array>
    <key>StartInterval</key>
    <integer>900</integer>
    <key>StandardOutPath</key>
    <string>/Users/kimhakin/job-alert/logs/pwc-watch.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/kimhakin/job-alert/logs/pwc-watch-error.log</string>
    <key>WorkingDirectory</key>
    <string>/Users/kimhakin/job-alert</string>
</dict>
</plist>
