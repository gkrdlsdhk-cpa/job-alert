# 네이버 개발자 센터에서 발급 (https://developers.naver.com)
NAVER_CLIENT_ID=여기에_클라이언트_ID
NAVER_CLIENT_SECRET=여기에_클라이언트_시크릿

# Gmail 알림 설정 (앱 비밀번호 사용 권장)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=your.email@gmail.com
EMAIL_PASSWORD=여기에_Gmail_앱_비밀번호
EMAIL_TO=your.email@gmail.com

# 브리핑 알림 채널: config.yaml → firm_news_briefing / saramin_briefing (telegram | kakao | email)

# 카카오톡 '나에게 보내기' — 실시간 공고·브리핑 channel: kakao (https://developers.kakao.com)
KAKAO_REST_API_KEY=여기에_REST_API_키
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8080
KAKAO_REFRESH_TOKEN=여기에_REFRESH_TOKEN

# 텔레그램 — 복약·주가·취업·tax 브리핑 (@BotFather, CLOUD_SETUP.md §10)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Webhook (Cloudflare Workers, CLOUD_SETUP.md §10-Webhook)
TELEGRAM_USE_WEBHOOK=1
TELEGRAM_WEBHOOK_URL=https://your-worker.workers.dev
TELEGRAM_WEBHOOK_SECRET=
