# 네이버 개발자 센터에서 발급 (https://developers.naver.com)
NAVER_CLIENT_ID=여기에_클라이언트_ID
NAVER_CLIENT_SECRET=여기에_클라이언트_시크릿

# Gmail 알림 설정 (앱 비밀번호 사용 권장)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=your.email@gmail.com
EMAIL_PASSWORD=여기에_Gmail_앱_비밀번호
EMAIL_TO=your.email@gmail.com

# 알림 방식: email (Gmail만) | kakao (Gmail + 카카오 알림) | both (Gmail + 카카오 알림)
NOTIFY_VIA=both

# 카카오톡 '나에게 보내기' (https://developers.kakao.com)
KAKAO_REST_API_KEY=여기에_REST_API_키
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8080
KAKAO_REFRESH_TOKEN=여기에_REFRESH_TOKEN
