<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jobalert.firm-news</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/kimhakin/job-alert/.venv/bin/python3</string>
        <string>/Users/kimhakin/job-alert/firm_news_briefing.py</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>23</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/kimhakin/job-alert/logs/firm-news-run.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/kimhakin/job-alert/logs/firm-news-error.log</string>
    <key>WorkingDirectory</key>
    <string>/Users/kimhakin/job-alert</string>
</dict>
</plist>
